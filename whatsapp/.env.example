# Firebase Admin (same project as web/bot — reuse those values)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Target group. Set EITHER the exact group name OR the group chat id
# (id looks like 120363012345678901@g.us). If only the name is set, the
# service resolves the id on first ready and logs it — paste it back here
# as WHATSAPP_GROUP_ID so it's stable even if the group is renamed.
WHATSAPP_GROUP_NAME=IEsports Tournament
WHATSAPP_GROUP_ID=

# Where the WhatsApp Web session is persisted (survives restarts; scan QR once)
WWEBJS_DATA_PATH=./.wwebjs_auth

# Optional: set to "true" to also relay messages while disconnected (queued)
